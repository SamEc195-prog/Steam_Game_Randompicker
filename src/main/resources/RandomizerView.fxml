<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ViewController"
      alignment="TOP_LEFT" spacing="10" prefWidth="650" prefHeight="500"
      style="-fx-padding: 10;">

    <children>
        <HBox spacing="10" VBox.vgrow="ALWAYS">
            
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Pool (Spiele zur Auswahl):" style="-fx-font-weight: bold;"/>
                <ListView fx:id="gamePoolListView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" style="-fx-padding-top: 50;">
                <Button fx:id="excludeButton" text="&gt;" onAction="#onExcludeClick" prefWidth="40"/>
                <Button fx:id="includeButton" text="&lt;" onAction="#onIncludeClick" prefWidth="40"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS">
                <Label text="Meine Bibliothek (Alle Spiele):" style="-fx-font-weight: bold;"/>
                <ListView fx:id="gameLibraryListView" VBox.vgrow="ALWAYS"/>
            </VBox>
            
        </HBox>

        <Button fx:id="randomButton" text="Wähle ein zufälliges Spiel aus dem POOL!" 
                onAction="#onRandomButtonClick" maxWidth="Infinity"/>
        
        <Label text="Zufälliges Spiel:" style="-fx-font-weight: bold; -fx-padding-top: 10;"/>
        <Label fx:id="resultLabel" text="... klick auf den Button ..." 
               style="-fx-font-size: 14px; -fx-background-color: #f0f0f0; -fx-padding: 5;"/>
    </children>
</VBox>