<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ViewController"
      alignment="TOP_LEFT" spacing="10" prefWidth="650" prefHeight="500"
      style="-fx-padding: 10;">

    <children>
        <HBox spacing="10" VBox.vgrow="ALWAYS">
            
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Pool (Spiele zur Auswahl):" style="-fx-font-weight: bold;"/>
                <ListView fx:id="gamePoolListView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" style="-fx-padding-top: 50;">
                <Button fx:id="excludeButton" text="&gt;" onAction="#onExcludeClick" prefWidth="40"/>
                <Button fx:id="includeButton" text="&lt;" onAction="#onIncludeClick" prefWidth="40"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="5">
                <Label text="Meine Bibliothek (Alle Spiele):" style="-fx-font-weight: bold;"/>
                <TextField fx:id="searchField" promptText="Spiel suchen..."/>
                <ListView fx:id="gameLibraryListView" VBox.vgrow="ALWAYS"/>
                
                <HBox spacing="5" alignment="CENTER_LEFT" style="-fx-padding-top: 5;">
                    <TextField fx:id="customGameField" promptText="Eigenes Spiel eingeben..." HBox.hgrow="ALWAYS"/>
                    <Button text="Hinzufügen" onAction="#onAddCustomGameClick"/>
                </HBox>
            </VBox>
            
        </HBox>

        <Button fx:id="randomButton" text="Wähle ein zufälliges Spiel aus dem POOL!" 
                onAction="#onRandomButtonClick" maxWidth="Infinity"/>
        
        <Label text="Zufälliges Spiel:" style="-fx-font-weight: bold; -fx-padding-top: 10;"/>
        
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
            <ImageView fx:id="resultImageView" fitWidth="184" preserveRatio="true"/>
            <Label fx:id="resultLabel" text="... klick auf den Button ..." 
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </children>
</VBox>