<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ViewController"
      alignment="TOP_LEFT" spacing="10" prefWidth="400" prefHeight="500"
      style="-fx-padding: 10;">

    <children>
        <Label text="Meine Steam-Spiele:" style="-fx-font-weight: bold;"/>

        <ListView fx:id="gameListView" VBox.vgrow="ALWAYS"/>

        <Button fx:id="randomButton" text="Wähle ein zufälliges Spiel!"
                onAction="#onRandomButtonClick" maxWidth="Infinity"/>

        <Label text="Zufälliges Spiel:" style="-fx-font-weight: bold; -fx-padding-top: 10;"/>
        <Label fx:id="resultLabel" text="... klick auf den Button ..."
               style="-fx-font-size: 14px; -fx-background-color: #f0f0f0; -fx-padding: 5;"/>
    </children>
</VBox>